# KiCad auto-saves and backups
*.bak
*.bck
*-backups/
_autosave-*
*.kicad_prl
fp-info-cache
~*.lck

# KiCad project local settings (per-user)
*.kicad_pro-bak

# Specctra / autorouter intermediate files (regenerable)
*.dsn
*.ses
temp-freerouting.dsn
freerouting.dsn

# 3D and DRC outputs (regenerable; keep fabrication/ outputs though)
/board.step
*.stl
drc.json
erc.json
# Note: *.wrl files in *.pretty/ directories ARE part of the design (3D models for footprints)
# so they are NOT ignored.

# Common OS files
.DS_Store
Thumbs.db
desktop.ini

# Portable toolchain (do not commit ~100MB JRE / Freerouting jar)
tools/

# Claude Code session artifacts
.claude/worktrees/

# Logs
logs/
